# Build artifacts
*.o
*.mod
*.mexa64
*.mexa64.dSYM/

# CMake build trees
build_*/
build_debug/
build_release/

# Fortran runtime scratch
fort.*

# SegMirMaker run artifacts (keep test_in/*.in inputs tracked)
segmirmaker/test_in/SegMirMaker
segmirmaker/test_in/*.presc
segmirmaker/test_in/*Hx.m

# Matlab autosave + output caches
*.asv
GMI/test_ff/*.mat

# Runtime binaries and resources copied into test_ff for convenience
GMI/test_ff/libpgplot.so
GMI/test_ff/grfont.dat

# macOS metadata
.DS_Store

# Large per-wavelength broadband result arrays (>100 MB each); keep
# rendered PNGs only.  These are regenerated by run_broadband_*.py.
pymacos/tests/proper_compare/results_cycle*/*.npz

# mmacos PROPER-comparison artefacts (regenerated by `make unittest`).
# Keep the results/ directory tracked via .gitkeep so the harness can
# write into it on a fresh checkout; ignore the rendered artefacts.
mmacos/tests/proper_compare/results/**/*.png
mmacos/tests/proper_compare/results/**/*.mat
mmacos/tests/proper_compare/results/phase*/
