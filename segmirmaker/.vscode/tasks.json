{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake Configure (Debug)",
      "type": "shell",
      "command": "source /opt/intel/oneapi/setvars.sh intel64 --force 2>/dev/null && cmake -S ${workspaceFolder} -B ${workspaceFolder}/build_debug_ifx -DCMAKE_BUILD_TYPE=Debug -DCMAKE_Fortran_COMPILER=ifx",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "CMake Build (Debug)",
      "type": "shell",
      "command": "source /opt/intel/oneapi/setvars.sh intel64 --force 2>/dev/null && cmake --build ${workspaceFolder}/build_debug_ifx -j$(nproc)",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc",
      "dependsOn": "CMake Configure (Debug)"
    }
  ]
}
